# ──────────────────────────────────────────────────────────────
# Gyan Sutra Backend — Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Firebase Admin SDK ───────────────────────────────────────
# Path to your Firebase service account JSON file (local dev only).
# On Render, paste the entire JSON content into FIREBASE_SERVICE_ACCOUNT_JSON instead.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Alternatively (preferred for Render deployment):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Your Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Google AI Studio ─────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Embedding model — generates 768-dimensional vectors
# text-embedding-004 is stable; gemini-embedding-exp-03-07 is higher quality
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Generation model — used only when retrieval threshold is met
GEMINI_GENERATION_MODEL=gemini-2.0-flash

# ── RAG Configuration ────────────────────────────────────────
# Minimum cosine similarity required to proceed to LLM generation.
# If no retrieved verse meets this threshold, the LLM is NEVER called.
# Range: 0.0–1.0. Recommended: 0.72
RAG_SIMILARITY_THRESHOLD=0.72

# Number of verses to retrieve per query before threshold filtering
RAG_TOP_K=8

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# Example: https://gyansutra.pages.dev,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── Rate Limiting ────────────────────────────────────────────
# Max requests per 15 minutes per IP on /ask endpoint
ASK_RATE_LIMIT_MAX=20
